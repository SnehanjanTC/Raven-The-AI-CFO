{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "raven-dev",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:$PATH && npm run dev -- --port $PORT --host 0.0.0.0"],
      "port": 3002,
      "autoPort": true
    },
    {
      "name": "raven-backend",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "cd backend && .venv/bin/uvicorn app.main:app --reload --port $PORT --host 0.0.0.0"],
      "port": 8000,
      "autoPort": true
    }
  ]
}
