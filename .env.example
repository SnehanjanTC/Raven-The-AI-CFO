# ============================================
# Raven Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file with real credentials!
# Use environment variables for secrets in production (don't use .env files)

# ============================================
# BACKEND CONFIGURATION
# ============================================

# -------------------------------------------
# Environment
# -------------------------------------------
# Set to "production" for production deployments
# Set to "development" for local development
ENVIRONMENT="development"

# Set to "true" for development, "false" for production
DEBUG=true

# -------------------------------------------
# Database (Required)
# -------------------------------------------
# Development: SQLite (default)
DATABASE_URL="sqlite+aiosqlite:///./raven.db"

# Production: PostgreSQL via Supabase
# DATABASE_URL="postgresql+asyncpg://user:password@host:5432/raven"
# Get from Supabase > Settings > Database > Connection String (PostgreSQL)

# -------------------------------------------
# Supabase (Required for production)
# -------------------------------------------
# Get these from: https://supabase.com → Your Project → Settings → API

# Supabase project URL
# Example: https://xyzabc.supabase.co
SUPABASE_URL="https://your-project.supabase.co"

# Supabase service role key (BACKEND ONLY)
# This is a secret key - never expose to frontend!
# Get from: Settings > API > Service Role Key
SUPABASE_SERVICE_KEY="your-service-role-key"

# Supabase JWT secret (for token verification)
# Get from: Settings > API > JWT Secret
SUPABASE_JWT_SECRET="your-jwt-secret"

# -------------------------------------------
# AI Provider (Required for production)
# -------------------------------------------
# CRITICAL: NEVER expose this to the frontend!
# This is a secret key - only set on backend!
# Get from: https://console.anthropic.com/

# Claude API key from Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# -------------------------------------------
# Security: Secrets & Keys (Required for production)
# -------------------------------------------
# Generate with: openssl rand -hex 32
# CRITICAL: Change these in production!

# Used for JWT signing and session management
# Must be at least 32 characters
SECRET_KEY="raven-dev-secret-key-change-in-production"

# Used for encrypting stored integration credentials
# Keep secure and don't lose it (can't decrypt old data without it)
ENCRYPTION_KEY="raven-dev-encryption-key-change-in-production"

# -------------------------------------------
# Security: CORS and Origins
# -------------------------------------------
# Comma-separated list of allowed frontend origins
# Format: https://app.example.com,https://staging.example.com
# Leave empty for defaults: http://localhost:3002,http://localhost:5173
ALLOWED_ORIGINS="http://localhost:3002,http://localhost:5173"

# -------------------------------------------
# Rate Limiting & Quotas
# -------------------------------------------
# Maximum tokens per month (Claude API usage limit)
# Adjust based on your Anthropic plan
MONTHLY_TOKEN_LIMIT="1000000"

# -------------------------------------------
# Error Tracking (Optional but recommended)
# -------------------------------------------
# Sentry DSN for backend error tracking
# Sign up at https://sentry.io to get a DSN
# Leave empty to disable Sentry
SENTRY_DSN=""

# ============================================
# FRONTEND CONFIGURATION (VITE_ PREFIX)
# ============================================
# Note: Frontend env vars are PUBLIC (visible in browser)
# NEVER put secrets in VITE_ variables!

# -------------------------------------------
# Supabase Frontend Access (Required)
# -------------------------------------------
# Get from: https://supabase.com → Your Project → Settings > API

# Supabase project URL (public)
# Example: https://xyzabc.supabase.co
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Supabase anonymous key (public)
# Get from: Settings > API > anon key
# This is used for client-side authentication
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# -------------------------------------------
# Backend API Configuration (Required)
# -------------------------------------------
# URL of the Raven backend API
# Development: http://localhost:8000
# Production: https://api.raven.com or https://api-prod.raven.com
VITE_API_URL="http://localhost:8000"

# -------------------------------------------
# Error Tracking (Optional but recommended)
# -------------------------------------------
# Sentry DSN for frontend error tracking
# Sign up at https://sentry.io to get a DSN
# Leave empty to disable Sentry
VITE_SENTRY_DSN=""

# ============================================
# DEVELOPMENT ONLY
# ============================================
# These should NEVER be set in production

# Enable HMR (Hot Module Reload) in development
# Set to "true" to disable (useful in certain setups)
DISABLE_HMR="false"

# ============================================
# QUICK START
# ============================================
# For local development:
# 1. Copy this file: cp .env.example .env
# 2. Leave SUPABASE_* and ANTHROPIC_API_KEY empty initially
# 3. The app will work with demo data
# 4. To connect to Supabase, fill in the URLs and keys
#
# For production deployment:
# 1. Set ENVIRONMENT=production
# 2. Set DEBUG=false
# 3. Fill in ALL required backend variables
# 4. Use environment variables (not .env files) for secrets
# 5. Follow DEPLOYMENT.md guide
