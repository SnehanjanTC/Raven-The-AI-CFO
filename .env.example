# ============================================
# FinOS Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your .env file with real credentials!

# -------------------------------------------
# Supabase (Required for database features)
# -------------------------------------------
# Get these from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# -------------------------------------------
# AI Provider Keys (At least one required for Copilot)
# -------------------------------------------
# Google Gemini (default provider)
# Get from: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY="your-gemini-api-key"

# Optional: Additional AI providers can be configured in the Settings page
# These are stored in localStorage via the UI, but can also be set here:
# VITE_OPENAI_API_KEY="your-openai-api-key"
# VITE_ANTHROPIC_API_KEY="your-anthropic-api-key"
# VITE_GROK_API_KEY="your-grok-api-key"
