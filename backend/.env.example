# FinOS Backend Configuration
# Copy this to .env and fill in your values

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./finos.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/finos

# Security
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:3002"]

# AI Provider Keys (optional - for CFO Copilot)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=

# Encryption key for stored integration credentials
ENCRYPTION_KEY=
