# Raven Backend Configuration
# Copy this to .env and fill in your values

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./raven.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/raven

# Security
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:3002"]

# AI Provider Key (Claude/Anthropic only)
ANTHROPIC_API_KEY=

# Encryption key for stored integration credentials
ENCRYPTION_KEY=
